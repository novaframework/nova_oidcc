{erl_opts, [debug_info]}.

{dialyzer, [
    {plt_extra_apps, [cowboy]}
]}.

{xref_ignores, [
    {nova_oidcc, config, 0},
    {nova_oidcc, start_provider, 2},
    {nova_oidcc_controller, login, 1},
    {nova_oidcc_controller, callback, 1}
]}.

{deps, [
    {nova, "~> 0.13"},
    {oidcc, "~> 3.7"}
]}.

%% Exclude Elixir-only transitive deps from oidcc's igniter
{overrides, [
    {override, oidcc, [
        {deps, [
            {jose, "~> 1.11"},
            {telemetry, "~> 1.2"},
            {telemetry_registry, "~> 0.3"}
        ]}
    ]}
]}.

{project_plugins, [
    erlfmt,
    rebar3_hex,
    rebar3_ex_doc
]}.

{erlfmt, [write]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {deps, []}
    ]}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.

{ex_doc, [
    {source_url, <<"https://github.com/novaframework/nova_oidcc">>},
    {main, <<"readme">>},
    {extras, [
        <<"README.md">>,
        <<"guides/configuration.md">>,
        <<"guides/multiple-providers.md">>,
        <<"guides/route-protection.md">>
    ]},
    {groups_for_extras, [
        {<<"Guides">>, [
            <<"guides/configuration.md">>,
            <<"guides/multiple-providers.md">>,
            <<"guides/route-protection.md">>
        ]}
    ]}
]}.
